# ── 공통 ────────────────────────────────────────────────────────
OPENAI_API_KEY=
LANGSMITH_API_KEY=
ELASTICSEARCH_URL=http://host.docker.internal:9200
TAVILY_API_KEY=

# ── DB 백엔드 선택: sqlite (로컬/테스트) | mysql (프로덕션) ────
DB_BACKEND=sqlite


# ── JWT 인증 ─────────────────────────────────────────────────────
JWT_SECRET_KEY=dev-secret-change-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── RDS MySQL (DB_BACKEND=mysql 일 때만 필요) ────────────────────
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_HOST=<RDS-endpoint>.rds.amazonaws.com
MYSQL_PORT=3306
MYSQL_SCHEMA=
SECRET_KEY=fisaai6

# ── S3 정적 파일 ─────────────────────────────────────────────────
# 로컬: /static (FastAPI StaticFiles 로컬 서빙)
# 프로덕션: https://<버킷>.s3.ap-northeast-2.amazonaws.com
STATIC_BASE_URL=/static
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=
